{
  "name": "Supply Chain BI",
  "dataColors": [
    "#2563EB",
    "#1E40AF",
    "#93C5FD",
    "#16A34A",
    "#D97706",
    "#DC2626",
    "#1A2B4A",
    "#DBEAFE"
  ],
  "background": "#F0F2F5",
  "foreground": "#1A2B4A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "fontFamily": [{ "value": "Segoe UI" }],
        "fontSize": [{ "value": 12 }]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{
          "fontSize": [{ "value": 28 }],
          "fontFamily": [{ "value": "Segoe UI" }],
          "color": [{ "solid": { "color": "#1A2B4A" } }]
        }],
        "label": [{
          "fontSize": [{ "value": 11 }],
          "color": [{ "solid": { "color": "#6B7280" } }]
        }]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [{ "defaultColor": { "solid": { "color": "#2563EB" } } }],
        "valueAxis": [{
          "gridlineColor": { "solid": { "color": "#E8EAF0" } },
          "labelColor": { "solid": { "color": "#6B7280" } }
        }],
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#6B7280" } }
        }]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [{ "defaultColor": { "solid": { "color": "#2563EB" } } }],
        "valueAxis": [{
          "gridlineColor": { "solid": { "color": "#E8EAF0" } },
          "labelColor": { "solid": { "color": "#6B7280" } }
        }],
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#6B7280" } }
        }]
      }
    },
    "gauge": {
      "*": {
        "dataPoint": [{ "defaultColor": { "solid": { "color": "#2563EB" } } }]
      }
    },
    "slicer": {
      "*": {
        "header": [{
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "background": { "solid": { "color": "#1A2B4A" } },
          "fontSize": [{ "value": 11 }]
        }],
        "items": [{
          "fontColor": { "solid": { "color": "#1A2B4A" } },
          "fontSize": [{ "value": 11 }]
        }]
      }
    },
    "tableEx": {
      "*": {
        "header": [{
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#1A2B4A" } },
          "fontSize": [{ "value": 11 }]
        }],
        "rows": [{
          "fontColor": { "solid": { "color": "#1A2B4A" } },
          "fontSize": [{ "value": 11 }]
        }]
      }
    }
  }
}
